{
  "enabledPlugins": {},
  "permissions": {
    "allow": [
      "Bash(devbox run:*)",
      "Bash(devbox services:*)",
      "Bash(devbox search:*)",
      "Bash(devbox update:*)",
      "Bash(devbox info:*)",
      "Bash(devbox list:*)",
      "Bash(devbox shell -- go:*)",
      "Bash(go doc:*)",
      "Bash(go list:*)",
      "Bash(go version:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/run-opengrep-on-write.sh"
          },
          {
            "type": "command",
            "command": "./.claude/hooks/check-lint-suppressions.sh"
          }
        ]
      }
    ]
  }
}
