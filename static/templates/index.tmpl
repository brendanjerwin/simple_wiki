<!DOCTYPE html>
<html>
    <head>
        <meta http-equiv="content-type" content="text/html; charset=UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
        <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
        <link rel="manifest" href="/static/manifest.json">

        <link rel="stylesheet" href="/static/vendor/css/fontawesome.min.css">
        <link rel="stylesheet" href="/static/vendor/css/solid.min.css">
        <link rel="stylesheet" href="/static/vendor/css/github-markdown.css">
        <link rel="stylesheet" href="/static/vendor/css/menus-min.css">
        <link rel="stylesheet" href="/static/vendor/css/base-min.css">
        <link rel="stylesheet" href="/static/vendor/css/highlight.css">

        <meta name="color-scheme" content="light dark">
        <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">
        <meta name="theme-color" content="#1e1e1e" media="(prefers-color-scheme: dark)">
        <meta name="simple-wiki-url" content="{{ .WikiBaseURL }}">

        {{ if and .CustomCSS .ReadPage }}
            <link rel="stylesheet" type="text/css" href="/static/css/custom.css">
        {{ else }}
            <link rel="stylesheet" type="text/css" href="/static/css/default.css">
        {{ end }}

        <script src="/static/vendor/js/highlight.min.js"></script>

        <script type="module" src="/static/js/dist/web-components.js"></script>

        <title>{{ .Page }}</title>

        <script type='text/javascript'>
            document.addEventListener('DOMContentLoaded', function() {
                hljs.highlightAll();
            });
            window.simple_wiki = {
                debounceMS: {{ .Debounce }},
                lastFetch: {{ .UnixTime }},
                pageName: "{{ .Page }}",
            }
        </script>
    </head>
    <body id="pad" class="
        {{ if .EditPage }} EditPage {{ end }}
        {{ if .ViewPage }} ViewPage {{ end }}
        {{ if .ReadPage }} ReadPage {{ end }}
        {{ if .DontKnowPage }} DontKnowPage {{ end }}
        {{ if .DirectoryPage }} DirectoryPage {{ end }}
        {{ if .HasDotInName }} HasDotInName {{ end }}
    ">
        <article class="markdown-body">

            {{ if .ReadPage  }}
                <!-- No menu for read page -->
            {{ else }}
                <div class="pure-menu pure-menu-horizontal" id="menu">
                    <ul class="pure-menu-list">
                        <li class="tools-menu pure-menu-item pure-menu-allow-hover">
                            <a href="#" id="tools-menu" class="pure-menu-link"><i class="fa-solid fa-bars"></i></a>
                            <ul class="pure-menu-children">
                                <li class="pure-menu-item"><a href="/" class="pure-menu-link"><i class="fa-solid fa-home"></i> Home</a></li>
                                <hr>
                                {{ if .ViewPage }}
                                <li class="pure-menu-item"><a href="/{{ .Page }}/edit" class="pure-menu-link"><i class="fas fa-pen-to-square"></i> Edit</a></li>
                                {{ end }}
                                {{ if .EditPage }}
                                <li class="pure-menu-item"><a href="/{{ .Page }}/view" class="pure-menu-link"><i class="fas fa-eye"></i> View</a></li>
                                {{ end }}
                                <hr id="utilityMenuSection">
                                {{ if not .EditPage }}
                                <li class="pure-menu-item"><a href="#" class="pure-menu-link" id="editFrontmatter"><i class="fas fa-file-lines"></i> Edit Frontmatter</a></li>
                                <hr>
                                {{ end }}
                                <li class="pure-menu-item"><a href="#" class="pure-menu-link" id="erasePage"><i class="fas fa-recycle"></i> Erase</a></li>
                            </ul>
                        </li>
                    </ul>
                    {{ if .ViewPage }}
                    <wiki-search id="site-search"></wiki-search>
                    {{ end }}
                </div>
            {{ end }}

            <div id="wrap">
                {{ if .EditPage }}
                    <wiki-editor
                        page="{{ .Page }}"
                        {{ if .AllowFileUploads }}allow-uploads{{ end }}
                        max-upload-mb="{{ if .MaxUploadMB }}{{ .MaxUploadMB }}{{ else }}10{{ end }}"
                        debounce-ms="{{ .Debounce }}"
                    ></wiki-editor>
                {{ end }}

                <div id="rendered" aria-live="polite" aria-label="Page content">
                    {{ if .DontKnowPage }}
                        <strong>
                            <center>
                                {{ .Route }} not understood!
                            </center>
                        </strong>
                    {{ end }}

                    {{ if .ViewPage }}
                        {{ .RenderedPage }}
                    {{ end }}

                    {{ if .ReadPage }}
                        {{ .RenderedPage }}
                    {{ end }}


                    {{ if .DirectoryPage }}
                        {{ if .DirectoryErrors }}
                        <div class="directory-error-banner">
                            <strong>⚠ Warning: the following pages could not be loaded:</strong>
                            <ul>
                            {{ range .DirectoryErrors }}
                                <li>{{ .PageName }}: {{ .Err }}</li>
                            {{ end }}
                            </ul>
                        </div>
                        {{ end }}
                        <table style="width:100%">
                          {{ $upload := .UploadPage }}
                          <tr>
                            <th>Document</th>
                            <th>Current size</th>
                            <th>Last Edited</th>
                          </tr>
                          {{range .DirectoryEntries}}
                          <tr>
                            <td>
                                {{ if $upload }}
                                <a href="/uploads/{{ .Name }}">{{ sniffContentType .Name }}</a>
                                {{ else }}
                                <a href="/{{ .Name }}/view">{{ .Name }}</a>
                                {{ end }}
                            </td>
                            <td>{{.Size}}</td>
                            <td>{{.ModTime.Format "Mon Jan 2 15:04:05 MST 2006" }}</td>
                          </tr>
                          {{ end }}
                          {{ range .DirectoryErrors }}
                          <tr class="directory-error-row">
                            <td colspan="3">⚠ <strong>{{ .PageName }}</strong> — could not be loaded: {{ .Err }}</td>
                          </tr>
                          {{ end }}
                        </table>
                    {{ end }}
                </div>
            </div>
        </article>
        {{ if not .EditPage }}
        <system-info></system-info>
        {{ end }}
        {{ if .ViewPage }}
        <page-auto-refresh page-name="{{ .Page }}"></page-auto-refresh>
        <page-chat-panel page="{{ .Page }}" persona="{{ .ChatPersona }}"></page-chat-panel>
        {{ end }}
        <frontmatter-editor-dialog id="frontmatter-dialog"></frontmatter-editor-dialog>
        <inventory-add-item-dialog id="inventory-add-dialog"></inventory-add-item-dialog>
        <inventory-move-item-dialog id="inventory-move-dialog"></inventory-move-item-dialog>
        <inventory-find-item-dialog id="inventory-find-dialog"></inventory-find-item-dialog>
        <page-import-dialog id="page-import-dialog"></page-import-dialog>
    </body>
</html>
